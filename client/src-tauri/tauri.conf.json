{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "SecureGuard",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "clipboard": {
        "all": true,
        "writeText": true,
        "readText": true
      },
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.secureguard.app",
      "publisher": "Aesterial ",
      "icon": ["icons/icon.ico"],
      "targets": ["nsis"]
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    },
    "windows": [
      {
        "title": "SecureGuard",
        "width": 900,
        "height": 500,
        "resizable": false,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ]
  }
}
